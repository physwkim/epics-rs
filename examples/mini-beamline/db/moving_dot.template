# MovingDot area detector template
# Macros: P, R, PORT, DTYP
# Includes ADBase-equivalent records + MovingDot-specific records.

# ===== Acquire control =====

record(bo, "$(P)$(R)Acquire") {
    field(DTYP, "$(DTYP)")
    field(ZNAM, "Done")
    field(ONAM, "Acquire")
}

record(bi, "$(P)$(R)Acquire_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(ZNAM, "Done")
    field(ONAM, "Acquire")
}

record(mbbo, "$(P)$(R)ImageMode") {
    field(DTYP, "$(DTYP)")
    field(ZRST, "Single")
    field(ONST, "Multiple")
    field(TWST, "Continuous")
}

record(mbbi, "$(P)$(R)ImageMode_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(ZRST, "Single")
    field(ONST, "Multiple")
    field(TWST, "Continuous")
}

record(longout, "$(P)$(R)NumImages") {
    field(DTYP, "$(DTYP)")
}

record(longin, "$(P)$(R)NumImages_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)NumImagesCounter_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
}

record(ao, "$(P)$(R)AcquireTime") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(EGU,  "s")
}

record(ai, "$(P)$(R)AcquireTime_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(PREC, "3")
    field(EGU,  "s")
}

record(ao, "$(P)$(R)AcquirePeriod") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(EGU,  "s")
}

record(ai, "$(P)$(R)AcquirePeriod_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(PREC, "3")
    field(EGU,  "s")
}

# ===== Status =====

record(mbbi, "$(P)$(R)DetectorState_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(ZRST, "Idle")
    field(ONST, "Acquire")
    field(TWST, "Readout")
    field(THST, "Correct")
    field(FRST, "Saving")
    field(FVST, "Aborting")
    field(SXST, "Error")
    field(SVST, "Waiting")
    field(EIST, "Initializing")
    field(NIST, "Disconnected")
    field(TEST, "Aborted")
}

record(bi, "$(P)$(R)AcquireBusy_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(ZNAM, "Done")
    field(ONAM, "Busy")
}

