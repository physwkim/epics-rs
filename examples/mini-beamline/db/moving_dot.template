# ===== MovingDot-specific: Motor positions + beam current + shutter =====

record(ao, "$(P)$(R)MotorXPos") {
    field(DTYP, "$(DTYP)")
    field(OMSL, "closed_loop")
    field(DOL,  "$(P)dot:mtrx.RBV CP")
    field(PREC, "4")
}

